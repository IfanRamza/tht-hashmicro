<%- include('../partials/header', { title, isAuthenticated }) %>

<main class="shell">
  <div class="page-head">
    <h1>Orders</h1>
    <a class="button" href="/orders/create">Create Order</a>
  </div>
  <table>
    <thead>
      <tr>
        <th>Code</th>
        <th>Customer</th>
        <th>Status</th>
        <th>Total</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach((order) => { %>
        <tr>
          <td><%= order.code %></td>
          <td><%= order.customer.name %></td>
          <td><%= order.status %></td>
          <td>Rp <%= order.getGrandTotal().toLocaleString('id-ID') %></td>
          <td class="actions">
            <a class="button button-secondary" href="/orders/<%= order.id %>">Show</a>
            <% if (order.status === 'confirmed') { %>
              <form action="/orders/<%= order.id %>/mark-as-paid" method="POST">
                <button type="submit" class="button button-success">Mark as Paid</button>
              </form>
            <% } %>
            <% if (order.status !== 'paid' && order.status !== 'cancelled') { %>
              <form action="/orders/<%= order.id %>/cancel" method="POST">
                <button type="submit" class="button button-danger">Cancel</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</main>

<%- include('../partials/footer') %>
