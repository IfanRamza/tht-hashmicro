<%- include('../partials/header', { title, isAuthenticated }) %>

<main class="shell">
  <h1><%= title %></h1>
  <form action="<%= action %>" method="POST" class="form panel">
    <label>
      Name
      <input name="name" value="<%= customer?.name ?? '' %>" required>
    </label>
    <label>
      Email
      <input name="email" type="email" value="<%= customer?.email ?? '' %>" required>
    </label>
    <label>
      Phone
      <input name="phone" value="<%= customer?.phone ?? '' %>" required>
    </label>
    <label>
      Type
      <select name="customerType" required>
        <% customerTypes.forEach((type) => { %>
          <option value="<%= type %>" <%= customer?.customerType === type ? 'selected' : '' %>><%= type %> (<%= (discountRates[type] * 100).toFixed(0) %>% discount)</option>
        <% }) %>
      </select>
    </label>
    <p class="helper-text">Discount rates: Regular 0%, Member 5%, Corporate 10%.</p>
    <label>
      Address
      <input name="address" value="<%= customer?.address ?? '' %>" required>
    </label>
    <div class="actions">
      <button type="submit">Save</button>
      <a class="button button-cancel" href="/customers">Cancel</a>
    </div>
  </form>
</main>

<%- include('../partials/footer') %>
